# Protein Evaluator Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# SECURITY SETTINGS (Required in production)
# =============================================================================
# Flask secret key for session management and CSRF protection
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secure-secret-key-here-change-this-in-production

# Flask environment: development | production
# In production mode, SECRET_KEY must be set or the app will refuse to start
FLASK_ENV=development

# =============================================================================
# AI API CONFIGURATION
# =============================================================================
# Your AI API key (OpenAI, DeepSeek, or Anthropic)
AI_API_KEY=your-api-key-here

# AI model to use
# Examples: deepseek-reasoner, gpt-4o, claude-3-opus, gemini-1.5-pro
AI_MODEL=deepseek-reasoner

# Temperature for AI responses (0.0 - 1.0, lower = more deterministic)
AI_TEMPERATURE=0.3

# Maximum tokens for AI responses
AI_MAX_TOKENS=20000

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Server host (0.0.0.0 to accept connections from any IP)
HOST=0.0.0.0

# Server port
PORT=5002

# Debug mode (True for development, False for production)
DEBUG=True

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================
# Custom API base URL (for proxy or self-hosted models)
# AI_API_BASE=https://api.deepseek.com

# Cache directory for UniProt data
# UNIPROT_CACHE_DIR=uniprot_cache

# Cache directory for PDB data
# PDB_CACHE_DIR=pdb_cache
